
{
  "entities": {
    "Usuario": {
      "title": "Usuario",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "email": { "type": "string" },
        "puntosTotales": { "type": "number" },
        "modoEstrictoActivo": { "type": "boolean" },
        "spotifyPlaylistUrl": { "type": "string" }
      },
      "required": ["id", "nombre", "email"]
    },
    "Proyecto": {
      "title": "Proyecto",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "color": { "type": "string" },
        "fechaCreacion": { "type": "string" }
      },
      "required": ["id", "nombre"]
    },
    "Materia": {
      "title": "Materia",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "proyectoId": { "type": "string" },
        "nombre": { "type": "string" }
      },
      "required": ["id", "proyectoId", "nombre"]
    },
    "Tarea": {
      "title": "Tarea",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "materiaId": { "type": "string" },
        "titulo": { "type": "string" },
        "estado": { "type": "string", "enum": ["Pendiente", "En Proceso", "Completada"] },
        "esfuerzoEstimadoPomodoros": { "type": "number" },
        "completadosPomodoros": { "type": "number" },
        "subtareas": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "titulo", "estado"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/usuarios/{usuarioId}": {
      "schema": { "$ref": "#/entities/Usuario" }
    },
    "/usuarios/{usuarioId}/proyectos/{proyectoId}": {
      "schema": { "$ref": "#/entities/Proyecto" }
    },
    "/usuarios/{usuarioId}/materias/{materiaId}": {
      "schema": { "$ref": "#/entities/Materia" }
    },
    "/usuarios/{usuarioId}/tareas/{tareaId}": {
      "schema": { "$ref": "#/entities/Tarea" }
    }
  }
}
