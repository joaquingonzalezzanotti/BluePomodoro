{
  "entities": {
    "Usuario": {
      "title": "Usuario",
      "type": "object",
      "description": "Perfil de usuario de BluePomodoro.",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "puntosTotales": { "type": "number" },
        "modoEstrictoActivo": { "type": "boolean" },
        "spotifyPlaylistUrl": { "type": "string", "description": "URL personalizada de la lista de Spotify del usuario." },
        "fechaRegistro": { "type": "string", "format": "date-time" },
        "sitiosBloqueados": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Lista de dominios a bloquear durante el modo Focus."
        }
      },
      "required": ["id", "nombre", "email"]
    },
    "Tarea": {
      "title": "Tarea",
      "type": "object",
      "description": "Tarea individual vinculada a un usuario.",
      "properties": {
        "id": { "type": "string" },
        "usuarioId": { "type": "string" },
        "titulo": { "type": "string" },
        "estado": { "type": "string", "enum": ["Pendiente", "En Proceso", "Completada"] },
        "prioridad": { "type": "string", "enum": ["Alta", "Media", "Baja"] },
        "esfuerzoEstimadoPomodoros": { "type": "number" },
        "fechaVencimiento": { "type": "string" },
        "subtareas": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["id", "usuarioId", "titulo", "estado"]
    },
    "Proyecto": {
      "title": "Proyecto",
      "type": "object",
      "description": "Materia o proyecto para organizar tareas.",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "tipo": { "type": "string", "enum": ["Materia", "Proyecto"] },
        "fechaCreacion": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nombre", "tipo"]
    },
    "SesionPomodoro": {
      "title": "Sesión Pomodoro",
      "type": "object",
      "description": "Registro de una sesión de estudio completada.",
      "properties": {
        "usuarioId": { "type": "string" },
        "tipo": { "type": "string", "enum": ["trabajo", "descanso"] },
        "duracionMinutos": { "type": "number" },
        "fecha": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/usuarios/{usuarioId}": {
      "schema": { "$ref": "#/entities/Usuario" },
      "description": "Documentos raíz de usuario."
    },
    "/usuarios/{usuarioId}/tareas/{tareaId}": {
      "schema": { "$ref": "#/entities/Tarea" },
      "description": "Colección de tareas del usuario."
    },
    "/usuarios/{usuarioId}/proyectos/{proyectoId}": {
      "schema": { "$ref": "#/entities/Proyecto" },
      "description": "Colección de proyectos/materias del usuario."
    },
    "/usuarios/{usuarioId}/sesionesPomodoro/{sesionId}": {
      "schema": { "$ref": "#/entities/SesionPomodoro" },
      "description": "Historial de sesiones pomodoro."
    }
  }
}