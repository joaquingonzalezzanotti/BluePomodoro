rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * BluePomodoro: Modelo de Seguridad de Firestore
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(usuarioId) {
      return isSignedIn() && request.auth.uid == usuarioId;
    }

    function isExistingOwner(usuarioId) {
      return isOwner(usuarioId) && resource != null;
    }

    function isValidCreation(usuarioId, fieldName) {
      return isOwner(usuarioId) && request.resource.data[fieldName] == usuarioId;
    }

    function isValidUpdate(usuarioId, fieldName) {
      return isExistingOwner(usuarioId) && request.resource.data[fieldName] == resource.data[fieldName];
    }

    match /usuarios/{usuarioId} {
      allow get, list: if isOwner(usuarioId);
      allow create: if isValidCreation(usuarioId, 'id');
      allow update: if isValidUpdate(usuarioId, 'id');
      allow delete: if isExistingOwner(usuarioId);

      match /tareas/{tareaId} {
        allow get, list: if isOwner(usuarioId);
        allow create: if isValidCreation(usuarioId, 'usuarioId');
        allow update: if isValidUpdate(usuarioId, 'usuarioId');
        allow delete: if isExistingOwner(usuarioId);
      }

      match /proyectos/{proyectoId} {
        allow get, list: if isOwner(usuarioId);
        allow create, update: if isOwner(usuarioId);
        allow delete: if isExistingOwner(usuarioId);
      }

      match /sesionesPomodoro/{sesionId} {
        allow get, list: if isOwner(usuarioId);
        allow create: if isValidCreation(usuarioId, 'usuarioId');
        allow update: if isValidUpdate(usuarioId, 'usuarioId');
        allow delete: if isExistingOwner(usuarioId);
      }

      match /configuracionesSincronizacionGoogle/{confId} {
        allow get, list: if isOwner(usuarioId);
        allow create, update: if isOwner(usuarioId);
        allow delete: if isExistingOwner(usuarioId);
      }
    }
  }
}