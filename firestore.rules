rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * BluePomodoro: Modelo de Seguridad de Firestore
     * Acceso basado en la propiedad del documento (UID del usuario).
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(usuarioId) {
      return isSignedIn() && request.auth.uid == usuarioId;
    }

    // Reglas para la colección de usuarios y sus subcolecciones
    match /usuarios/{usuarioId} {
      // El usuario solo puede leer y escribir su propio perfil
      allow read, write: if isOwner(usuarioId);

      // Reglas para tareas
      match /tareas/{tareaId} {
        allow read, write: if isOwner(usuarioId);
      }

      // Reglas para proyectos/materias
      match /proyectos/{proyectoId} {
        allow read, write: if isOwner(usuarioId);
      }

      // Reglas para sesiones de pomodoro registradas
      match /sesionesPomodoro/{sesionId} {
        allow read, write: if isOwner(usuarioId);
      }

      // Reglas para configuración de sincronización
      match /configuracionesSincronizacionGoogle/{confId} {
        allow read, write: if isOwner(usuarioId);
      }
    }
  }
}