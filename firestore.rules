rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * BluePomodoro: Modelo de Seguridad Simplificado y Robusto
     * El usuario tiene control total sobre su documento de perfil y cualquier subcolección.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(usuarioId) {
      return isSignedIn() && request.auth.uid == usuarioId;
    }

    // Regla recursiva para el nodo de usuario
    match /usuarios/{usuarioId} {
      // Permite leer y escribir en el documento del usuario
      allow read, write: if isOwner(usuarioId);
      
      // Permite leer y escribir en CUALQUIER subcolección de forma recursiva (tareas, proyectos, sesiones, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(usuarioId);
      }
    }
  }
}